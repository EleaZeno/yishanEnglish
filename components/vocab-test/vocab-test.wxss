/* 忆闪 - 词汇量测试样式（增强版） */

.vocab-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
  background: var(--color-white);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.vocab-close {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  font-size: 36rpx;
  color: var(--color-slate-400);
  padding: 16rpx;
}

/* ========== 介绍页 ========== */
.vocab-intro {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 560rpx;
  width: 100%;
  gap: 24rpx;
}

.vocab-intro-icon { font-size: 96rpx; }

.vocab-intro-title {
  font-size: 52rpx;
  font-weight: 900;
  color: var(--color-slate-900);
  letter-spacing: -2rpx;
}

.vocab-intro-desc {
  font-size: 26rpx;
  color: var(--color-slate-500);
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.vocab-intro-hint {
  font-size: 20rpx;
  color: var(--color-slate-400);
  font-weight: 700;
}

/* ========== 测试中 ========== */
.vocab-test {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 560rpx;
  gap: 24rpx;
}

.vocab-progress {
  display: flex;
  width: 100%;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.vocab-stage-label {
  font-size: 18rpx;
  font-weight: 800;
  color: var(--color-slate-400);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.vocab-stage-num {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--color-slate-800);
}

.vocab-word-card {
  width: 100%;
  background: var(--color-slate-50);
  border-radius: var(--radius-xl);
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  border: 2rpx solid var(--color-slate-100);
}

.vocab-word-term {
  font-size: 80rpx;
  font-weight: 900;
  color: var(--color-slate-900);
  letter-spacing: -2rpx;
}

.vocab-level-dots {
  display: flex;
  gap: 10rpx;
}

.vocab-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-slate-200);
}

.vocab-dot.active { background: var(--color-primary); }

.vocab-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  margin-top: 16rpx;
}

.vocab-footer-hint {
  font-size: 18rpx;
  color: var(--color-slate-300);
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-top: 16rpx;
}

/* ========== 结果 ========== */
.vocab-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 560rpx;
  gap: 16rpx;
}

.vocab-result-icon { font-size: 96rpx; }

.vocab-result-label {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--color-slate-400);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.vocab-result-value {
  font-size: 120rpx;
  font-weight: 900;
  color: var(--color-slate-900);
  letter-spacing: -4rpx;
  line-height: 1;
}

.vocab-result-ci { margin-bottom: 16rpx; }

/* 各级分布 */
.vocab-level-breakdown {
  width: 100%;
  margin-bottom: 24rpx;
}

.level-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.level-name {
  width: 100rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-slate-500);
  text-align: right;
}

.level-bar-track {
  flex: 1;
  height: 12rpx;
  background: var(--color-slate-100);
  border-radius: 6rpx;
  overflow: hidden;
}

.level-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), #10b981);
  border-radius: 6rpx;
  transition: width 0.5s ease;
  min-width: 4rpx;
}

.level-rate {
  width: 64rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: var(--color-slate-600);
}

.vocab-result-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 8rpx;
}