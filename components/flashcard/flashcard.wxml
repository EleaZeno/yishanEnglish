<!-- 忆闪 YiShan v3 - 闪卡组件：音标 + 例句 + 词性 + 质量评分 --><view class="flashcard-root"><!-- 质量评分浮层 --><view class="quality-overlay {{showQuality ? 'active' : ''}}" wx:if="{{showQuality}}"><view class="quality-card"><text class="quality-title">回忆质量评分</text><text class="quality-desc">诚实选择，SM-2 算法将据此调整复习间隔</text><view class="quality-buttons"><view class="q-btn q-5" data-level="5" bindtap="onSelectQuality"><text class="q-num">5</text><text class="q-label">完美·无需思考</text></view><view class="q-btn q-4" data-level="4" bindtap="onSelectQuality"><text class="q-num">4</text><text class="q-label">正确·稍作回忆</text></view><view class="q-btn q-3" data-level="3" bindtap="onSelectQuality"><text class="q-num">3</text><text class="q-label">正确·费力回忆</text></view><view class="q-btn q-2" data-level="2" bindtap="onSelectQuality"><text class="q-num">2</text><text class="q-label">错误·但见过答案就想起</text></view><view class="q-btn q-1" data-level="1" bindtap="onSelectQuality"><text class="q-num">1</text><text class="q-label">完全遗忘</text></view></view><view class="quality-skip" bindtap="onSkipQuality"><text class="q-skip-text">跳过 · 使用默认评分 (3)</text></view></view></view><!-- 滑动方向指示器 --><view class="action-indicator action-left {{_indicatorSide === 'left' && _indicatorOpacity > 0.2 ? 'visible' : ''}}" style="opacity: {{_indicatorSide === 'left' ? _indicatorOpacity : 0}}; transform: translateY(-50%) scale({{0.6 + _indicatorOpacity * 0.4}})"><view class="action-badge action-badge-master"><view class="ab-icon ab-icon-check"></view></view><text class="action-text">已掌握</text></view><view class="action-indicator action-right {{_indicatorSide === 'right' && _indicatorOpacity > 0.2 ? 'visible' : ''}}" style="opacity: {{_indicatorSide === 'right' ? _indicatorOpacity : 0}}; transform: translateY(-50%) scale({{0.6 + _indicatorOpacity * 0.4}})"><view class="action-badge action-badge-review"><view class="ab-icon ab-icon-again"></view></view><text class="action-text">再复习</text></view><!-- 可拖拽卡片区 --><view class="card-drag-shell" style="transform: translateX({{_dx}}px) rotate({{_rotation}}deg); transition: {{_transition}}; opacity: {{_opacity || 1}}" bindtouchstart="onTouchStart" catchtouchmove="onTouchMove" bindtouchend="onTouchEnd"><view class="card-inner {{isFlipped ? 'flipped' : ''}}" catchtap="onFlip"><!-- ★ 正面：单词 + 音标 + 词性 --><view class="card-face card-front"><view class="front-shine"></view><view class="front-top-meta" wx:if="{{word.partOfSpeech || word.phonetic}}"><text class="front-pos" wx:if="{{word.partOfSpeech}}">{{word.partOfSpeech}}</text><text class="front-phonetic" wx:if="{{word.phonetic}}">{{word.phonetic}}</text></view><text class="front-word">{{word.word || '—'}}</text><view class="front-speaker" wx:if="{{word.word}}" catchtap="onSpeak"><text class="speaker-icon">🔊</text></view><view class="front-sub" wx:if="{{word.stage && word.stage !== 'new'}}"><text class="tag" style="opacity:0.7;font-size:20rpx;">{{word.stage === 'mastered' ? '🧠 已掌握' : '📖 复习中'}}</text></view><view class="front-footer"><view class="stability-bar" wx:if="{{word.stability > 0}}"><view class="stability-fill" style="width: {{word.stability}}%"></view></view><text class="front-hint">轻触翻转 · 左右滑动评分</text></view></view><!-- ★ 背面：释义 + 例句 + 谐音 --><view class="card-face card-back"><text class="back-word">{{word.definition || '暂无释义'}}</text><view class="back-divider"></view><view class="back-meta" wx:if="{{word.examples && word.examples.length}}"><text class="meta-label">📝 例句</text><text class="meta-value meta-example" wx:for="{{word.examples}}" wx:key="*this" wx:for-item="ex">{{ex}}</text></view><view class="back-meta" wx:if="{{word.sounds_like}}"><text class="meta-label">🔊 谐音记忆</text><text class="meta-value">{{word.sounds_like}}</text></view><view class="back-meta" wx:if="{{word.category}}"><text class="meta-label">分类</text><text class="tag tag-primary" style="display:inline-flex;">{{word.category}}</text></view><view class="back-meta" wx:if="{{word.tags && word.tags.length}}"><text class="meta-label">标签</text><view class="tag-row"><text class="tag tag-slate" style="margin-right:8rpx;margin-bottom:4rpx;" wx:for="{{word.tags}}" wx:key="*this" wx:for-item="t">{{t}}</text></view></view></view></view></view></view>