/* 忆闪 YiShan - 新手引导页样式 */
.guide-root {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-primary);
  padding: 0 40rpx;
}
.guide-steps {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 48rpx 0 32rpx;
}
.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--border);
  transition: all 0.3s;
}
.step-dot.active {
  width: 48rpx;
  border-radius: 8rpx;
  background: var(--accent-gradient);
}
.guide-content { flex: 1; display: flex; flex-direction: column; }
.g-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
  text-align: center;
}
.g-emoji { font-size: 96rpx; margin-bottom: 16rpx; }
.g-title { font-size: 44rpx; font-weight: 800; color: var(--text-primary); margin-bottom: 12rpx; }
.g-subtitle { font-size: 28rpx; color: var(--text-secondary); line-height: 1.5; }
.g-features { display: flex; flex-direction: column; gap: 24rpx; }
.g-feature {
  display: flex; gap: 20rpx; padding: 28rpx;
  background: var(--bg-card); border-radius: var(--radius-lg);
  border: 1rpx solid var(--border);
}
.gf-icon { font-size: 48rpx; flex-shrink: 0; }
.gf-title { font-size: 30rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 6rpx; }
.gf-desc { font-size: 24rpx; color: var(--text-secondary); line-height: 1.4; }
.g-stages { display: flex; flex-direction: column; gap: 20rpx; }
.gs-item {
  display: flex; align-items: flex-start; gap: 20rpx;
  padding: 28rpx; background: var(--bg-card);
  border-radius: var(--radius-lg); border: 1rpx solid var(--border);
}
.gs-num {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: var(--accent-gradient); color: white;
  font-size: 28rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.gs-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 6rpx; }
.gs-desc { font-size: 24rpx; color: var(--text-secondary); line-height: 1.4; }
.g-algo { display: flex; flex-direction: column; gap: 16rpx; }
.ga-row { display: flex; gap: 16rpx; }
.ga-card {
  flex: 1; padding: 28rpx 20rpx;
  background: var(--bg-card); border: 1rpx solid var(--border);
  border-radius: var(--radius-lg); text-align: center;
  display: flex; flex-direction: column; align-items: center;
}
.ga-num {
  font-size: 48rpx; font-weight: 800;
  background: var(--accent-gradient);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.ga-label { font-size: 24rpx; color: var(--text-secondary); margin-top: 4rpx; }
.ga-desc { font-size: 22rpx; color: var(--text-tertiary); margin-top: 4rpx; }
.g-note {
  margin-top: 32rpx; padding: 24rpx;
  background: var(--success-bg); border-radius: var(--radius-md);
  border-left: 6rpx solid var(--success);
}
.gn-text { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; }
.g-ready-tips {
  display: flex; flex-direction: column; gap: 16rpx;
  padding: 32rpx; background: var(--bg-card);
  border-radius: var(--radius-lg); border: 1rpx solid var(--border);
}
.gt-label { font-size: 28rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 8rpx; }
.gt-item { font-size: 26rpx; color: var(--text-secondary); line-height: 1.8; }
.guide-footer {
  display: flex; align-items: center;
  padding: 40rpx 0 env(safe-area-inset-bottom); gap: 24rpx;
}
.guide-skip { text-align: center; padding: 0 0 40rpx; }
.guide-skip text { font-size: 26rpx; color: var(--text-tertiary); }