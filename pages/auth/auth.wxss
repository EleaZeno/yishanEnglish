/* 忆闪 YiShan v3 - 登录页样式 */
.auth-page {
  min-height: 100vh;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

/* ========== 品牌区 ========== */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 80rpx;
}

.brand-logo {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  animation: logoFloat 3s ease-in-out infinite;
}

@keyframes logoFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.brand-name {
  font-size: 56rpx;
  font-weight: 900;
  color: var(--text-primary);
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.brand-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ========== 微信登录 ========== */
.wx-login-section {
  width: 100%;
  max-width: 600rpx;
  margin-bottom: 32rpx;
}

.btn-wechat {
  width: 100%;
  border-radius: var(--radius-md);
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 700;
  background: #07c160;
  color: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
}

.btn-wechat-icon {
  font-size: 32rpx;
}

.btn-wechat:active {
  opacity: 0.85;
}

.divider-text {
  text-align: center;
  padding: 24rpx 0 12rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ========== 登录/注册卡片 ========== */
.auth-card {
  width: 100%;
  max-width: 600rpx;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 48rpx 40rpx;
  box-shadow: var(--shadow-lg);
}

.form-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 36rpx;
}

.input {
  background: var(--bg-tertiary);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.input::placeholder {
  color: var(--text-tertiary);
}

.input:focus {
  border-color: var(--border-focus);
}

.error-box {
  background: var(--danger-bg);
  border: 2rpx solid var(--danger);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  color: var(--danger);
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.mode-switch {
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: var(--accent-primary);
}

/* ========== 按钮 ========== */
.btn {
  width: 100%;
  border-radius: var(--radius-md);
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  text-align: center;
  margin-top: 16rpx;
}

.btn-primary {
  background: var(--accent-primary);
  color: #fff;
  box-shadow: var(--shadow-sm);
}

.btn-primary:active {
  opacity: 0.85;
}

/* ========== 游客入口 ========== */
.guest-row {
  display: flex;
  justify-content: center;
  margin-top: 48rpx;
  padding: 20rpx 0;
}

.guest-link {
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 600;
}

/* ========== 底部声明 ========== */
.auth-footer {
  margin-top: auto;
  padding: 60rpx 40rpx 80rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.auth-footer text:first-child {
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 700;
}

.auth-footer text:last-child {
  color: var(--text-tertiary);
  font-size: 20rpx;
}