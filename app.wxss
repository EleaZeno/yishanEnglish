/* 忆闪 YiShan v3 - 全局样式 + 暗色模式 */
/* ========== 设计 Token ========== */
page {
  --bg-primary: #f8fafc;
  --bg-secondary: #ffffff;
  --bg-tertiary: #f1f5f9;
  --bg-card: #ffffff;
  --bg-glass: rgba(255,255,255,0.65);
  --text-primary: #0f172a;
  --text-secondary: #475569;
  --text-tertiary: #94a3b8;
  --text-inverse: #ffffff;
  --accent-primary: #6366f1;
  --accent-primary-light: #818cf8;
  --accent-secondary: #a855f7;
  --accent-gradient: linear-gradient(135deg, #6366f1, #a855f7,#ec4899);
  --success: #10b981;
  --success-bg: #ecfdf5;
  --warning: #f59e0b;
  --warning-bg: #fffbeb;
  --danger: #ef4444;
  --danger-bg: #fef2f2;
  --border: #e2e8f0;
  --border-focus: #6366f1;
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
  --shadow-lg: 0 12px 32px rgba(0,0,0,0.10);
  --shadow-xl: 0 20px 60px rgba(0,0,0,0.12);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system,BlinkMacSystemFont,'PingFang SC','Helvetica Neue',sans-serif;
  transition: background-color 0.3s, color 0.3s;
}

/* ========== 暗色模式 ========== */
@media (prefers-color-scheme: dark) {
  page {
    --bg-primary: #0f172a;
    --bg-secondary: #1e293b;
    --bg-tertiary: #334155;
    --bg-card: #1e293b;
    --bg-glass: rgba(30,41,59,0.75);
    --text-primary: #f1f5f9;
    --text-secondary: #94a3b8;
    --text-tertiary: #64748b;
    --text-inverse: #0f172a;
    --accent-primary: #818cf8;
    --accent-primary-light: #a5b4fc;
    --accent-gradient: linear-gradient(135deg,#818cf8,#a78bfa,#f472b6);
    --success: #34d399;
    --success-bg: rgba(52,211,153,0.12);
    --warning: #fbbf24;
    --warning-bg: rgba(251,191,36,0.12);
    --danger: #f87171;
    --danger-bg: rgba(248,113,113,0.12);
    --border: #334155;
    --border-focus: #818cf8;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.3);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.4);
    --shadow-lg: 0 12px 32px rgba(0,0,0,0.5);
    --shadow-xl: 0 20px 60px rgba(0,0,0,0.6);
  }
}

/* 手动暗色模式类 */
page.dark-mode {
  --bg-primary: #0f172a;
  --bg-secondary: #1e293b;
  --bg-tertiary: #334155;
  --bg-card: #1e293b;
  --bg-glass: rgba(30,41,59,0.75);
  --text-primary: #f1f5f9;
  --text-secondary: #94a3b8;
  --text-tertiary: #64748b;
  --text-inverse: #0f172a;
  --accent-primary: #818cf8;
  --accent-primary-light: #a5b4fc;
  --accent-gradient: linear-gradient(135deg,#818cf8,#a78bfa,#f472b6);
  --success: #34d399;
  --success-bg: rgba(52,211,153,0.12);
  --warning: #fbbf24;
  --warning-bg: rgba(251,191,36,0.12);
  --danger: #f87171;
  --danger-bg: rgba(248,113,113,0.12);
  --border: #334155;
  --border-focus: #818cf8;
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.3);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.4);
  --shadow-lg: 0 12px 32px rgba(0,0,0,0.5);
  --shadow-xl: 0 20px 60px rgba(0,0,0,0.6);
}

/* ========== 基础工具 ========== */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; }
.gap-8 { gap: 8rpx; }
.gap-12 { gap: 12rpx; }
.gap-16 { gap: 16rpx; }
.gap-24 { gap: 24rpx; }

/* Tag */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.5;
}
.tag-primary { background: var(--accent-primary); color: white; }
.tag-slate { background: var(--bg-tertiary); color: var(--text-secondary); }
.tag-success { background: var(--success-bg); color: var(--success); }
.tag-warning { background: var(--warning-bg); color: var(--warning); }
.tag-danger { background: var(--danger-bg); color: var(--danger); }
.tag-row { display: flex; flex-wrap: wrap; }

/* Card */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border);
}

.card-glass {
  background: var(--bg-glass);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border);
}

/* Button */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 40rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s;
}
.btn:active { opacity: 0.85; transform: scale(0.98); }
.btn-primary { background: var(--accent-gradient); color: white; box-shadow: 0 4rpx 16rpx rgba(99,102,241,0.3); }
.btn-outline { background: transparent; color: var(--accent-primary); border: 2rpx solid var(--accent-primary); }
.btn-ghost { background: var(--bg-tertiary); color: var(--text-secondary); }
.btn-sm { padding: 8rpx 24rpx; font-size: 24rpx; }
.btn-block { width: 100%; }
.btn-destructive { background: var(--danger); color: white; }

/* Glass Navigation Bar */
.glass-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--bg-glass);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  padding: env(safe-area-inset-top) 32rpx 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.glass-nav-title {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: -0.5px;
}

/* ========== 页面过渡 ========== */
.page-enter {
  animation: pageIn 0.3s ease-out;
}
@keyframes pageIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}
.empty-emoji { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 30rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; }

/* ========== Loading Spinner ========== */
.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--accent-primary);
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ========== Toast / Alert ========== */
.alert {
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  margin-bottom: 24rpx;
  line-height: 1.5;
}
.alert-info { background: rgba(99,102,241,0.1); border-left: 6rpx solid var(--accent-primary); color: var(--accent-primary); }
.alert-success { background: var(--success-bg); border-left: 6rpx solid var(--success); color: #065f46; }
.alert-warning { background: var(--warning-bg); border-left: 6rpx solid var(--warning); color: #92400e; }
.alert-error { background: var(--danger-bg); border-left: 6rpx solid var(--danger); color: #991b1b; }